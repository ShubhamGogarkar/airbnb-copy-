<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-7xl">
      <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
     Hey host! Here are your registered homes on AirBnB:
      </h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      <% registeredHomes.forEach(home => { %>
      <li class="bg-white rounded-lg shadow-md hover:shadow-xl transition duration-300 overflow-hidden border border-gray-200">
        <div class="w-full h-40 overflow-hidden bg-gray-200">
        <img src="<%= home.image %>" alt="<%= home.houseName %>" class="w-full h-full object-cover hover:scale-105 transition duration-300">
        </div>
        <div class="p-4">
        <h3 class="text-base font-bold text-gray-900 mb-2"><%= home.houseName %></h3>
        <p class="text-gray-500 text-xs mb-3">📍<%= home.location %></p>
        <div class="flex justify-between items-center">
        <span class="text-xl font-bold text-red-500">₹<%= home.price %></span>
        <div class="flex gap-2">
          <a href="/host/edit-home/<%= home._id %>?editing=true" class="bg-blue-500 text-white px-3 py-1 text-sm rounded hover:bg-blue-600 transition flex-1 text-center">Edit</a>
         <form action="/host/delete-home" method="POST">
          <input type="hidden" name="homeId" value="<%= home._id %>">
          <button type="submit" class="bg-red-500 text-white px-3 py-1 text-sm rounded hover:bg-red-600 transition flex-1">Delete</button></form>
        </div>
        </div>
        </div>
      </li>
      <% }) %>
      </ul>
    </main>
  </body>
</html>
