<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto mt-8 p-8 bg-white rounded-lg shadow-md">
      <h1 class="text-3xl font-bold mb-6 text-center text-gray-800"><%=  editing ? "Edit" : "Register" %> Your Home on AirBnB</h1>
      <form action="/host/<%=  editing ? 'edit-home' : 'add-home' %>" method="POST" enctype="multipart/form-data" class="max-w-md mx-auto">
        <% if (editing) { %>
          <input type="hidden" name="homeId" value="<%= home._id %>">
        <% } %>
        <input
          type="text"
          value="<%=  editing ? home.houseName : '' %>"
          name="houseName"
          placeholder="Enter your House Name"
          class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        />
        <input
          type="number"
          value="<%=editing ? home.price : '' %>"
          name="price"
          placeholder="Enter  Price per Night"
          class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        />
        <input
          type="text"
          value="<%=  editing ? home.location : '' %>"
          name="location"
          placeholder="Enter your House Location"
          class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        />
        <input
          type="file"
          accept="image/jpg, image/jpeg, image/png"
          value="<%=  editing ? home.image : '' %>"
          name="image"
          placeholder="Enter your House Image URL"
          class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        />
        <textarea
          type="text"
          
          name="description"
          placeholder="Enter your House Description"
          class="w-full px-4 py-2 mb-4 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        ><%=  editing ? home.description : '' %></textarea>
        <input type="submit" value="<%=  editing ? 'update home' : 'add home' %> " class="w-full bg-red-500 text-white py-2 rounded-md hover:bg-red-600 transition duration-300" />
      </form>
    </main> 
  </body>
</html>
