<%- include('../partials/head') %>
</head>
<body class="bg-gray-100 flex flex-col min-h-screen">
  <%- include('../partials/nav') %>
  <div class="flex justify-center items-center min-h-screen px-4">

   <div class="bg-white p-6 md:p-8 rounded shadow-md w-full max-w-sm">
    <h1 class="text-2xl md:text-3xl font-bold mb-6 text-center">Login</h1>
    
    <form method="POST" action="/login">
      <div class="mb-4">
       <label class="block text-gray-700 text-sm font-bold mb-2" for="email">
        Email
       </label>
       <input
        class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-red-500"
        type="email"
        name="email"
        required
        value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>"
        placeholder="abc@xyz.com"
       />
      </div>
      
      <div class="mb-6">
       <label class="block text-gray-700 text-sm font-bold mb-2" for="password">
        Password
       </label>
       <input
        class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-red-500"
        type="password"
        name="password"
        required
       />
      </div>
      
      <button
       class="w-full bg-red-500 text-white font-bold py-2 px-4 rounded hover:bg-red-600 transition duration-300"
       type="submit"
      >
       Login
      </button>
    </form>
    <p class="text-center text-gray-600 mt-4 text-sm md:text-base">
      Don't have an account? 
      <a href="/signUp" class="text-red-500 hover:text-red-700 font-semibold">Sign Up</a>
    </p>
   </div>
   
  </div>
  <%- include('../partials/errors') %>
</body>
</html>
