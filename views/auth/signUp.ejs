<%- include('../partials/head') %>
</head>
<body class="bg-gradient-to-br from-red-50 to-gray-100 min-h-screen flex flex-col">
  <%- include('../partials/nav') %>

  <div class="flex-1 flex items-center justify-center px-4 py-8">
    <div class="w-full max-w-sm">
      <div class="bg-white rounded-lg shadow-lg p-6 sm:p-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-center text-gray-800 mb-2">Create Account</h1>
        <p class="text-center text-gray-600 text-sm mb-6">Join us today</p>
        
        <form method="POST" action="/signup" class="space-y-4">
          <div>
            <label class="block text-gray-700 text-xs font-semibold mb-2" for="firstName">First Name</label>
            <input class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" type="text" name="firstName" value="<%= typeof oldInput !== 'undefined' ? oldInput.firstName : '' %>" placeholder="First Name" required />
          </div>
          <div>
            <label class="block text-gray-700 text-xs font-semibold mb-2" for="lastName">Last Name</label>
            <input class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" type="text" name="lastName" value="<%= typeof oldInput !== 'undefined' ? oldInput.lastName : '' %>" placeholder="Last Name" />
          </div>
          <div>
            <label class="block text-gray-700 text-xs font-semibold mb-2" for="email">Email</label>
            <input class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" type="email" name="email" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" placeholder="you@example.com" required />
          </div>
          <div>
            <label class="block text-gray-700 text-xs font-semibold mb-2" for="password">Password</label>
            <input class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" type="password" name="password" placeholder="••••••••" required />
          </div>
          <div>
            <label class="block text-gray-700 text-xs font-semibold mb-2" for="confirmPassword">Confirm Password</label>
            <input class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 text-sm transition" type="password" name="confirmPassword" placeholder="••••••••" required />
          </div>
          <div>
            <label class="block text-gray-700 text-xs font-semibold mb-3">I am a</label>
            <div class="flex gap-6">
              <label class="flex items-center text-gray-700 text-xs cursor-pointer">
                <input class="mr-2 w-4 h-4 accent-red-500 cursor-pointer" type="radio" name="userType" <% if (typeof oldInput !== 'undefined' && oldInput.userType === 'guest') { %>checked<% } %> value="guest" required />
                Guest
              </label>
              <label class="flex items-center text-gray-700 text-xs cursor-pointer">
                <input class="mr-2 w-4 h-4 accent-red-500 cursor-pointer" type="radio" name="userType" <% if (typeof oldInput !== 'undefined' && oldInput.userType === 'host') { %>checked<% } %> value="host" required />
                Host
              </label>
            </div>
          </div>
          <div>
            <label class="flex items-center text-gray-700 text-xs cursor-pointer">
              <input class="mr-2 w-4 h-4 accent-red-500 cursor-pointer" type="checkbox" name="termsAndConditions" required />
              <span>I agree to the <a href="#" class="text-red-500 hover:underline font-medium">Terms and Conditions</a></span>
            </label>
          </div>
          <button class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-2.5 px-4 rounded-lg transition duration-300 text-sm mt-6" type="submit">Sign Up</button>
          <p class="text-center text-gray-600 text-xs mt-4">Already have an account? <a href="/login" class="text-red-500 font-semibold hover:underline">Log in</a></p>
        </form>
      </div>
      <%- include('../partials/errors') %>
    </div>
  </div>
</body>
</html>
