<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="min-h-screen  from-gray-50 to-gray-100">
      <div class="max-w-5xl mx-auto px-4 py-12">
        
        <!-- Header -->
        <div class="mb-10">
          <h2 class="text-5xl font-bold text-gray-900 mb-2">
            <%= home.houseName %>
          </h2>
          <div class="flex items-center gap-2 text-gray-600">
            <span>📍</span>
            <p class="text-lg"><%= home.location %></p>
          </div>
        </div>

        <!-- Image Gallery Section -->
        <div class="mb-10 rounded-2xl overflow-hidden shadow-2xl">
          <img src="<%= home.image %>" alt="<%= home.houseName %>" class="w-full  object-cover hover:scale-105 transition duration-300">
        </div>

        <!-- Main Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          
          <!-- Left Column - Details -->
          <div class="lg:col-span-2">
            <div class="bg-white rounded-2xl shadow-lg p-8">
              
              <!-- Price Highlight -->
              <div class=" from-red-50 to-orange-50 rounded-xl p-6 mb-8 border-l-4 border-red-500">
                <p class="text-gray-600 text-sm font-semibold uppercase mb-2">Price per Night</p>
                <p class="text-5xl font-bold text-red-500">₹<%= home.price %></p>
              </div>

              <!-- Description -->
              <div>
                <h3 class="text-2xl font-bold text-gray-900 mb-4">About this property</h3>
                <p class="text-gray-700 leading-relaxed text-lg"><%= home.description %></p>
                
              </div>
            </div>
          </div>

          <!-- Right Column - Booking Card -->
          <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl shadow-lg p-8 sticky top-20 h-fit">
              <div class="mb-6">
                <p class="text-gray-600 text-sm font-semibold uppercase mb-2">Ready to book?</p>
                <p class="text-3xl font-bold text-gray-900">₹<%= home.price %></p>
                <p class="text-gray-500 text-sm">per night</p>
              </div>

              <!-- Action Buttons -->
              <div class="space-y-3">
              
                <% if (!isBooked) { %>
              
                <a href="/reserve/<%= home._id %>">
                  <button type="submit" class="w-full px-6 py-3 bg-linear-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold rounded-lg transition duration-300 shadow-md hover:shadow-lg">
                    Reserve Now
                  </button></a>

                  <% }  else { %>

                  <a href="/CancelBooking">
                  <button type="submit" class="w-full px-6 py-3 bg-linear-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold rounded-lg transition duration-300 shadow-md hover:shadow-lg">
                    Cancel Reservation
                  </button></a>
                  <% } %>

                  <input type="hidden" name="homeId" value="<%= home._id %>">
                </form>
                <div class="w-full">
                  <%- include('../partials/favourite', { home: home }) %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
