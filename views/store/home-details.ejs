<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-7xl">
      <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
      Here are the details of the home:<%= home.houseName %>
      </h2>
    <div class="bg-gray-50 rounded-lg p-6">
      <img src="<%= home.image %>" alt="<%= home.houseName %>" class="w-auto h-auto object-cover items-center rounded-lg mb-6">
      <div class="grid grid-cols-2 gap-6">
        <div>
          <p class="text-gray-600 text-sm mb-1">House Name</p>
          <p class="text-2xl font-bold text-gray-900"><%= home.houseName %></p>
        </div>
        <div>
          <p class="text-gray-600 text-sm mb-1">Price</p>
          <p class="text-2xl font-bold text-red-500">₹<%= home.price %>/night</p>
        </div>
        <div class="col-span-2">
          <p class="text-gray-600 text-sm mb-1">Location</p>
          <p class="text-xl font-bold text-red-500">📍<%= home.location %></p>
        </div>
        <div class="col-span-2">
          <p class="text-gray-600 text-sm mb-1">Description</p>
          <p class="text-gray-800"><%= home.description %></p>
        </div>
      </div>
         <%- include('../partials/favourite' , { home: home }) %>

           
    
    </main>
  </body>
</html>
