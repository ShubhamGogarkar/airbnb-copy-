<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto bg-white scroll-auto shadow-lg rounded-lg p-8 mt-10 max-w-2xl">
      <div class="flex items-center justify-between mb-6">
      <div></div>
        <h2 class="text-2xl font-semibold text-red-600">Your Messages</h2>

      <form action="/deleteAllMessages" method="POST">
        <button type="submit" class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded">
          Delete All Messages
        </button>
      </form>
      </div>
      
      <% if (messages.length === 0) { %>
        <p class="text-center text-gray-500 text-lg">No messages yet</p>
      <% } else { %>
        <div class="space-y-4">
          <% messages.forEach(message => { %>
            <div class="bg-gray-100 p-4 rounded-lg border-l-4 border-red-500">
              <p class="text-gray-700"><%= message %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>
  </body>
</html>