<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-2xl">
      <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
        Your Messages
      </h2>
      
      <% if (messages.length === 0) { %>
        <p class="text-center text-gray-500 text-lg">No messages yet</p>
      <% } else { %>
        <div class="space-y-4">
          <% messages.forEach(message => { %>
            <div class="bg-gray-100 p-4 rounded-lg border-l-4 border-red-500">
              <p class="text-gray-700"><%= message %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>
  </body>
</html>