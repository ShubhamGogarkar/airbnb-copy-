<%- include('../partials/head') %>
</head>
<body class="bg-gray-100 flex flex-col min-h-screen">
  <%- include('../partials/nav') %>
  <div class="flex justify-center items-center min-h-screen px-4">

   <div class="bg-white p-6 md:p-8 rounded shadow-md w-full max-w-sm">
    <h1 class="text-2xl md:text-3xl font-bold mb-6 text-center">Reservation</h1>
    
    <form method="POST" action="/bookings/<%= homeId %>">
      <div class="mb-4">
       <label class="block text-gray-700 text-sm font-bold mb-2" for="payment-method">
        Payment Method
       </label>
       <select
        class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-red-500"
        name="paymentMethod"
        id="payment-method"
        required
       >
        <option value="">Select Payment Method</option>
        <option value="credit-card">Credit Card</option>
        <option value="debit-card">Debit Card</option>
        <option value="paypal">PayPal</option>
        <option value="bank-transfer">Bank Transfer</option>
       </select>
      </div>
      
      <div class="mb-6">
       <label class="flex items-center text-gray-700 text-sm font-bold">
        <input
         class="mr-2 w-4 h-4 border border-gray-300 rounded focus:outline-none focus:border-red-500"
         type="checkbox"
         name="paymentConfirmation"
         required
        />
        I confirm that I have paid the required amount
       </label>
      </div>
      
      <div class="flex justify-end">
       <button
        class="bg-red-500 text-white font-bold py-2 px-6 rounded hover:bg-red-600 transition duration-300"
        type="submit"
       >
        Confirm Reservation
       </button>
      </div>
    </form>
   </div>
   
  </div>
  <%- include('../partials/errors') %>
</body>
</html>